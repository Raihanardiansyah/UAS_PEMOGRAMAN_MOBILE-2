<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".MainActivity">

    <View
        android:id="@+id/circleMainTop1"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:translationX="40dp"
        android:translationY="-40dp"
        android:background="@drawable/bg_circle_green_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circleMainTop2"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:translationX="80dp"
        android:translationY="-20dp"
        android:background="@drawable/bg_circle_green_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardBottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER AREA: SEKARANG ADA FOTO PROFILNYA, CUY -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <!-- Penampung Teks Hello + Foto Profil -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/ivChatIcon">

                    <!-- FIX FOTO PROFIL: Tempat nampilin foto profil dinamis pas diklik -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfileMain"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_marginEnd="12dp"
                        android:scaleType="centerCrop"
                        android:background="#DDDDDD"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:id="@+id/tvHelloMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello!☘️"
                        android:textColor="#1B4D22"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivChatIcon"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerInParent="true"
                    android:src="@android:drawable/stat_notify_chat"
                    android:background="@drawable/bg_circle_green_light"
                    android:padding="6dp"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Waste Collection Service"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="2dp"
                android:columnCount="3"
                android:rowCount="2">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="165dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1B4D22"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/sampah_general" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="General" android:textColor="#FFFFFF" android:layout_marginTop="16dp" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="165dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1A365D"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/organic" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Organic" android:textColor="#FFFFFF" android:layout_marginTop="16dp" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="165dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#6B8E23"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/construction" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Construction" android:textColor="#FFFFFF" android:layout_marginTop="16dp" android:textSize="12sp" android:textStyle="bold" android:textAlignment="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="165dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#CC0000"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/hazardous" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hazardous" android:textColor="#FFFFFF" android:layout_marginTop="16dp" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="165dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#004D40"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/sampah_2" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="General" android:textColor="#FFFFFF" android:layout_marginTop="16dp" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="165dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#FFFF00"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/daur_ulang" /> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recycling" android:textColor="#FFFFFF" android:layout_marginTop="16dp" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Info Kurir"
                android:textColor="#333333"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#E6ECE8"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- FIX FOTO KURIR: Diubah ID-nya jadi ivKurirDashboard biar sinkron sama Java -->
                    <ImageView
                        android:id="@+id/ivKurirDashboard"
                        android:layout_width="80dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:background="#CCCCCC"
                        android:src="@android:drawable/ic_menu_gallery"
                        tools:ignore="ContentDescription" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvInfoKurirUtama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status: Belum ada penjemputan 💤"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardBottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        app:cardElevation="10dp"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#528265"
            android:orientation="horizontal"
            android:weightSum="5">

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_view" android:contentDescription="Home"/>
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_save" android:contentDescription="Finance"/>
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_camera" android:contentDescription="Scan"/>
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_recent_history" android:contentDescription="History"/>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnTabProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_my_calendar" android:contentDescription="Profile"/>
            </FrameLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>